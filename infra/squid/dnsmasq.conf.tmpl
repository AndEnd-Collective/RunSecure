# ============================================================================
# RunSecure — dnsmasq Configuration Template
# ============================================================================
# Generated at runtime by infra/scripts/generate-egress-conf.sh from the
# project's dns: block in runner.yml.
#
# DO NOT edit by hand — rewritten on every orchestrator run.
# ============================================================================

# Do not read /etc/resolv.conf — use only the servers listed below.
no-resolv

# Do not read /etc/hosts — use only the hosts file below (if any).
no-hosts

# M1: listen on the proxy's internal-only IP, not 0.0.0.0.
# The proxy container has TWO networks attached:
#   - runner-net (internal: true, runner peers on 10.11.12.96/28)
#   - proxy-external (bridge to the host for upstream DNS/HTTPS)
# Binding 0.0.0.0 made dnsmasq accept queries on BOTH interfaces. We
# don't want anything outside the runner-net to be able to query us
# (cache poisoning, recursive amplification). bind-interfaces ensures
# dnsmasq actually honours listen-address (without it, dnsmasq binds
# 0.0.0.0 and uses listen-address only as a filter — fine for query
# filtering but wrong if the kernel ever delivers a packet via the
# external NIC).
listen-address=10.11.12.13
bind-interfaces
port=53

# Log queries (helps with audit; disable via dns.log_queries: false).
# LOG_QUERIES_PLACEHOLDER

# Upstream DNS servers (from dns.servers in runner.yml).
# SERVER_ENTRIES_PLACEHOLDER

# Optional static hosts file (from dns.hosts_file in runner.yml).
# HOSTS_FILE_PLACEHOLDER

# Optional query whitelist (from dns.whitelist_file in runner.yml).
# Queries for domains NOT in the whitelist are refused.
# WHITELIST_PLACEHOLDER

# Refuse all other queries (policy: deny unless whitelisted).
# This line is appended only when dns.whitelist_file is set.
# DENY_OTHER_PLACEHOLDER
