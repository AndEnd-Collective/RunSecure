# ============================================================================
# RunSecure — HAProxy TCP Egress Template
# ============================================================================
# Generated at runtime by infra/scripts/generate-egress-conf.sh from the
# project's tcp_egress list in runner.yml.
#
# DO NOT edit by hand — rewritten on every orchestrator run.
#
# Each tcp_egress entry "host:port" becomes a frontend/backend pair:
#   - frontend listens on 0.0.0.0:<port> (internal network only)
#   - backend proxies to host:<port>
#
# This file uses shell-variable placeholders (%%VAR%%) so the generator
# can do simple text substitution without requiring a template engine.
# ============================================================================

global
    log /dev/log local0
    maxconn 1024
    # M2: drop the stats socket from `level admin` (full-control over
    # haproxy state — disable servers, change weights, add/remove
    # frontends at runtime) to `level user` (read-only stats only). The
    # socket is unix-only and the proxy container has cap_drop ALL +
    # no-new-privileges, so the attack surface is small — but there is
    # no operational reason for runtime admin mutation of haproxy from
    # inside the container, so removing the capability is free.
    stats socket /var/lib/haproxy/admin.sock mode 660 level user
    stats timeout 30s
    # Run as the proxy user (already set by container USER directive)
    # but HAProxy needs daemon mode when started via -D flag.

defaults
    log     global
    mode    tcp
    option  tcplog
    option  dontlognull
    timeout connect 5s
    timeout client  60s
    timeout server  60s
    retries 3

# HAPROXY_RESOLVERS_PLACEHOLDER

